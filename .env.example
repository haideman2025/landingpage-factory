# Owner-only secrets — set these in Vercel → Project → Environment Variables.
# NEVER commit real values.

# Lead storage + server-side CAPI (Google Sheet via Service Account):
GOOGLE_SA_EMAIL=
GOOGLE_SA_PRIVATE_KEY=
OAUTH_REDIRECT_BASE=https://landingpage-factory.vercel.app

# Optional — only if you re-enable the multi-tenant "Kết nối Google" OAuth button:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
