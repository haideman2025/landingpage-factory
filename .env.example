# Owner-only secrets — set these in Vercel → Project → Environment Variables.
# NEVER commit real values.

# Required (Vercel-only deploy flow):
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://landingpage-factory.vercel.app

# Google "Kết nối & tạo Sheet" feature (auto COD-lead Sheet):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SA_EMAIL=
GOOGLE_SA_PRIVATE_KEY=

# Optional (only if you enable the GitHub "save source" step):
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
